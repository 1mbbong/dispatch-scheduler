# ============================================
# ORDI — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# --- Required ---------------------------------------------------

# PostgreSQL connection string (used by Prisma + pg adapter)
DATABASE_URL="postgresql://postgres:postgrespassword@127.0.0.1:5432/dispatch_scheduler?schema=public"

# JWT signing secret — MUST be changed in production!
JWT_SECRET="CHANGE_ME_IN_PRODUCTION"

# --- Optional ---------------------------------------------------

# JWT token lifetime (default: 7d)
JWT_EXPIRES_IN="7d"

# Node environment (development | production)
NODE_ENV="development"
